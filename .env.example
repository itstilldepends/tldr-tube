# ========================================
# LLM API Keys (Choose one or more)
# ========================================

# DeepSeek API Key (Recommended - Cheapest!)
# Get your key from: https://platform.deepseek.com/
# Pricing: ~$0.003/video (95% cheaper than Claude)
DEEPSEEK_API_KEY=sk-...

# Google Gemini API Key
# Get your key from: https://aistudio.google.com/apikey
# Pricing: ~$0.005/video
GOOGLE_API_KEY=AIza...

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
# Pricing: ~$0.01/video (GPT-4o-mini)
OPENAI_API_KEY=sk-proj-...

# Qwen API Key (Alibaba Cloud DashScope)
# Get your key from: https://dashscope.console.aliyun.com/
# Pricing: ~$0.05/video
# Best for Chinese content!
DASHSCOPE_API_KEY=sk-...

# Anthropic Claude API Key
# Get your key from: https://console.anthropic.com/
# Pricing: ~$0.10/video (Sonnet)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ========================================
# Local LLM (Ollama) — no API key needed
# ========================================

# Optional: override Ollama server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ========================================
# App Configuration
# ========================================

# App password for basic authentication (optional)
# If set, a password gate will be shown on app load.
# If left unset or commented out, the app is accessible without a password.
# APP_PASSWORD=your_secure_password_here

# Database connection string
# Default: SQLite (for local development)
# For Postgres: postgresql://user:password@localhost:5432/tldr_tube
DATABASE_URL=sqlite:///data/tldr_tube.db
